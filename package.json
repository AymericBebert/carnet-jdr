{
  "name": "carnet-jdr",
  "version": "1.0.0",
  "description": "Carnet JdR SPA/PWA",
  "repository": {
    "type": "git",
    "url": "https://github.com/AymericBebert/carnet-jdr"
  },
  "scripts": {
    "ng": "ng",
    "scrap": "tsx import/scrap.ts",
    "start": "ng serve",
    "start:public": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:serve": "ng build && npx http-server -p 4700 -c-1 dist/carnet-jdr/browser",
    "build:dev": "ng build --configuration development",
    "test": "ng test",
    "test:ci": "ng test --code-coverage --watch=false --browsers ChromeHeadlessNoSandbox",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix"
  },
  "author": "Aymeric BERNARD",
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/service-worker": "^21.2.5",
    "idb": "^8.0.3",
    "rxjs": "~7.8.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/language-service": "^21.2.5",
    "@eslint/js": "~10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "angular-eslint": "21.3.1",
    "cheerio": "^1.2.0",
    "eslint": "~10.1.0",
    "jasmine-core": "~6.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
