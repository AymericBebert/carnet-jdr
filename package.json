{
  "name": "carnet-jdr",
  "version": "1.0.0",
  "description": "Carnet JdR SPA/PWA",
  "repository": {
    "type": "git",
    "url": "https://github.com/AymericBebert/carnet-jdr"
  },
  "scripts": {
    "ng": "ng",
    "scrap": "tsx import/scrap.ts",
    "start": "ng serve",
    "start:public": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:serve": "ng build && npx http-server -p 4700 -c-1 dist/carnet-jdr/browser",
    "build:dev": "ng build --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix"
  },
  "author": "Aymeric BERNARD",
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/material": "^22.0.4",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@angular/service-worker": "^22.0.6",
    "idb": "^8.0.3",
    "rxjs": "~7.8.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@angular/language-service": "^22.0.6",
    "@eslint/js": "~10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "angular-eslint": "22.1.0",
    "cheerio": "^1.2.0",
    "eslint": "~10.7.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.3.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jsdom": "^29.1.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.0.8"
  }
}
